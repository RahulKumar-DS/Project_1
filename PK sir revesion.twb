      <aliases enabled='yes' />
      <column caption='LOGIC 2' datatype='string' name='[Calculation_0705617699049472]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit])&gt;=40000 THEN &quot;VERY HIGH PROFIT&quot;&#13;&#10;ELSEIF SUM([Profit])&gt;=20000 THEN &quot;HIGH PROFIT&quot;&#13;&#10;ELSEIF SUM([Profit])&gt;=0 THEN &quot;MEDIUM PROFIT&quot;&#13;&#10;ELSE &quot;LOSE&quot; END' />
      </column>
      <column caption='logical 3' datatype='string' name='[Calculation_0705617703706625]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit]) &gt; 0 THEN&#13;&#10;IF SUM([Profit]) &gt; 30000 THEN &quot;excellent&quot;&#13;&#10;ELSE &quot;good&quot;&#13;&#10;END&#13;&#10;ELSE &quot;loss&quot;&#13;&#10;END' />
      </column>
      <column caption='Logical F4' datatype='string' name='[Calculation_0705617707864066]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Sales]) &gt; 0 THEN&#13;&#10;IF SUM([Sales]) &gt; 50000 THEN &quot;excellent&quot;&#13;&#10;ELSEIF SUM([Sales]) &gt; 20000 then &quot;good&quot;&#13;&#10;ELSE &quot;average&quot;&#13;&#10;END&#13;&#10;ELSE &quot;loss&quot; END' />
      </column>
      <column caption='TOTAL SALES' datatype='real' name='[Calculation_0737503187689472]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales])' />
      </column>
      <column caption='LOGIC1' datatype='string' name='[Calculation_0737503195713541]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit]) &gt; 0 THEN &quot;HIGH PROFIT&quot;&#13;&#10;ELSE &quot;LOW PROFIT&quot; END' />
      </column>
      <column caption='Indexing' datatype='integer' name='[Calculation_1678688671330304]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INDEX()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top 10 Index' datatype='boolean' name='[Calculation_1678688672600065]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1678688671330304] &gt;= 10'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='TOTAL SALES BY FURNITURE' datatype='real' name='[Calculation_1781491946020864]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF[Category]= &quot;FURNITURE&quot; THEN  [Sales] END)' />
      </column>
      <column caption='Sub by Quantity' datatype='string' name='[Calculation_2062969412067329]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Quantity]) &gt;= 250 THEN&#13;&#10;IF SUM([Quantity]) &gt; 1000 THEN &quot;high quantity&quot;&#13;&#10;ELSE &quot;good quantity&quot;&#13;&#10;END&#13;&#10;ELSE &quot;low quantity&quot;&#13;&#10;END' />
      </column>
